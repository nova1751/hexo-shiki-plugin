{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "skipLibCheck": true,
    "types": ["node", "vite/client"],
    "noEmit": true
  },
  "include": [
    "src",
    "tests",
    "vite.config.ts",
    "vite.client.config.ts",
    "vitest.config.ts"
  ]
}
